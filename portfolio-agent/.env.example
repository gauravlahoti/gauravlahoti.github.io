# portfolio-agent environment variables
# Copy to .env and fill in real values for local development.
# .env is gitignored — never commit credentials.

# --- Gemini API key (AI Studio, free tier) ---
# Required for local dev without gcloud application-default credentials.
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Audit log (Spec #23) ---
# URL of the resume-gate Worker's agent log endpoint.
# Local dev: http://localhost:8787/api/agent-log
# Production: https://gaurav-portfolio-resume-gate.gaurav-lahoti25.workers.dev/api/agent-log
AGENT_LOG_URL=http://localhost:8787/api/agent-log

# Shared secret matching `wrangler secret put AGENT_LOG_TOKEN` on the Worker.
# Use any random 32+ char string for local dev (e.g., openssl rand -hex 16).
# Leave both AGENT_LOG_URL and AGENT_LOG_TOKEN empty to disable audit logging entirely.
AGENT_LOG_TOKEN=dev-token

# --- Cloud Run telemetry (optional) ---
# GCS bucket for OpenTelemetry traces (metadata only, no content).
# LOGS_BUCKET_NAME=your-gcs-bucket-name

# --- CORS ---
# Comma-separated list of allowed origins for the agent API.
ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- send_resume action tool ---
# Resend API key. Get one at https://resend.com/api-keys.
# In production, wire from Secret Manager via `--secrets RESEND_API_KEY=resend-api-key:latest`.
RESEND_API_KEY=

# Verified-domain From address. Domain must be verified in your Resend dashboard
# (DKIM/SPF/Return-Path TXT records added at the registrar). Free tier with
# `onboarding@resend.dev` only sends to your registered email — no good here.
RESEND_FROM_ADDRESS=resume@your-verified-domain.com

# Public URL of the resume PDF that gets attached to outbound emails.
# Defaults to the GitHub Pages copy if unset.
RESUME_PDF_URL=https://gauravlahoti.github.io/assets/img/resume.pdf
